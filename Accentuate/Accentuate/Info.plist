<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Standard bundle keys. Xcode substitutes $(PRODUCT_BUNDLE_IDENTIFIER) etc. from build settings. -->
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- Hide from Dock and App Switcher. Input methods are background agents. -->
    <key>LSUIElement</key>
    <true/>

    <!--
        IMK: The Mach port name IMKServer registers under.
        MUST match the string passed to IMKServer(name:) in main.swift exactly.
    -->
    <key>InputMethodConnectionName</key>
    <string>Accentuate_Connection</string>

    <!--
        IMK: The ObjC class name of your IMKInputController subclass.
        Must match the @objc(…) annotation on the class in Swift.
    -->
    <key>InputMethodServerControllerClass</key>
    <string>AccentuateInputController</string>
    <key>InputMethodServerDelegateClass</key>
    <string>AccentuateInputController</string>

    <!--
        Input source identity and language metadata shown in Keyboard settings.
    -->
    <key>TISInputSourceID</key>
    <string>com.accentuate.inputmethod.Accentuate</string>
    <key>TISIntendedLanguage</key>
    <string>en</string>
    <key>tsInputMethodCharacterRepertoireKey</key>
    <array>
        <string>Latn</string>
    </array>

    <!--
        Declare a single visible mode so the source is treated as a
        mode-enabled keyboard input method by Text Services.
    -->
    <key>ComponentInputModeDict</key>
    <dict>
        <key>tsInputModeListKey</key>
        <dict>
            <key>com.accentuate.inputmethod.Accentuate.Roman</key>
            <dict>
                <key>TISInputSourceID</key>
                <string>com.accentuate.inputmethod.Accentuate.Roman</string>
                <key>TISIntendedLanguage</key>
                <string>en</string>
                <key>tsInputModeDefaultStateKey</key>
                <true/>
                <key>TISIconLabels</key>
                <dict>
                    <key>Primary</key>
                    <string>A</string>
                </dict>
                <key>tsInputModeIsVisibleKey</key>
                <true/>
                <key>tsInputModePrimaryInScriptKey</key>
                <true/>
                <key>tsInputModeScriptKey</key>
                <string>smUnicode</string>
            </dict>
        </dict>
        <key>tsVisibleInputModeOrderedArrayKey</key>
        <array>
            <string>com.accentuate.inputmethod.Accentuate.Roman</string>
        </array>
    </dict>
</dict>
</plist>
